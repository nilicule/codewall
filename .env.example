# NET2GRID activity wall configuration.
# Copy to .env (loaded automatically in local dev) and fill in.
# With NO GITHUB_TOKEN set, the app serves mock data so the UI runs with zero
# infrastructure and no secrets.

# --- GitHub harvesting ---
# Server-side token (GitHub App installation token or PAT) with read access to
# the org's repos. NEVER sent to the client. Leave empty to use mock data.
GITHUB_TOKEN=
GITHUB_ORG=NET2GRID
WINDOW_DAYS=90
REFRESH_SECONDS=120
# How often the mock source ticks (only used when GITHUB_TOKEN is empty).
MOCK_REFRESH_SECONDS=3

# --- Auth / session ---
# Used to sign the Flask session cookie. Set a long random value in production.
SECRET_KEY=
# Viewer gate. Pick ONE (precedence: DEV_AUTH_BYPASS > ACCESS_TOKEN > OAuth):
#
# 1) Shared secret (simplest): one access key, entered once via a login form.
#    No OAuth app needed. Anyone with the key can view.
ACCESS_TOKEN=
#
# 2) Google Workspace OAuth (per-user identity + hosted-domain check). Leave
#    empty to disable. Callback URL must be <host>/callback. Only accounts in
#    ALLOWED_EMAIL_DOMAIN may sign in (default net2grid.com).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=net2grid.com
#
# 3) Local-only escape hatch: 1 = skip auth and treat every request as a member.
#    INSECURE. Never enable in production.
DEV_AUTH_BYPASS=0

# --- Reverse proxy ---
# Set when served behind nginx under a sub-path so login/API/redirect URLs are
# built correctly (e.g. /codewall). Leave empty when served at the domain root.
URL_PREFIX=

# --- Optional persistence ---
# Empty = pure in-memory. Set to a file path to persist the snapshot across
# restarts via a single local SQLite file (no server). The parent directory is
# created automatically. Use a RELATIVE path so the same value works everywhere:
# in local dev it resolves under the project directory, and in the container it
# resolves under /app (mount a volume at /app/data to keep it across recreations).
CACHE_PERSIST_PATH=data/snapshot.sqlite
